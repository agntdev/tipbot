[
  {
    "name": "plain text gets help hint",
    "steps": [
      {
        "send": { "text": "Hi" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Use /tip for a kind tip, /count to see how many tips have been served." } }
        ]
      }
    ]
  },
  {
    "name": "photo message receives help hint",
    "steps": [
      {
        "send": {
          "update": {
            "update_id": 1,
            "message": {
              "message_id": 1,
              "date": 0,
              "chat": { "id": 1, "type": "private", "first_name": "Test" },
              "from": { "id": 1, "is_bot": false, "first_name": "Test" },
              "photo": [
                { "file_id": "photo_1", "file_unique_id": "u1", "width": 100, "height": 100, "file_size": 1000 }
              ]
            }
          }
        },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Use /tip for a kind tip, /count to see how many tips have been served." } }
        ]
      }
    ]
  }
]