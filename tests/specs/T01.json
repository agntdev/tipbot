[
  {
    "name": "/start replies with a welcome",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Welcome! I am ready to help." } }
        ]
      }
    ]
  },
  {
    "name": "bot responds to a plain-text update",
    "steps": [
      {
        "send": { "text": "Hello bot" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "I received your message." } }
        ]
      }
    ]
  }
]
