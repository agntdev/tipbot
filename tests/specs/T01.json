[
  {
    "name": "/start replies with a welcome",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Welcome to AGNTDev Bot! I am your assistant. Use the menu below to get started.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Features", "callback_data": "main:features" }],
                  [{ "text": "Help", "callback_data": "main:help" }],
                  [{ "text": "About", "callback_data": "main:about" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "bot responds to a plain-text update",
    "steps": [
      {
        "send": { "text": "Hello bot" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Use /tip for a kind tip, /count to see how many tips have been served." } }
        ]
      }
    ]
  }
]
