[
  {
    "name": "/help lists available commands",
    "steps": [
      {
        "send": { "text": "/help" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Available commands:\n/start — Start the bot\n/help — Show this help" } }
        ]
      }
    ]
  },
  {
    "name": "unknown command replies with friendly fallback",
    "steps": [
      {
        "send": { "text": "/nonsense" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Sorry, I don't recognize that command. Try /help to see what I can do." } }
        ]
      }
    ]
  },
  {
    "name": "plain text still works",
    "steps": [
      {
        "send": { "text": "Hello there" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "I received your message." } }
        ]
      }
    ]
  }
]
